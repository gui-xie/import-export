{
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "description": "imexport-table root package.json",
  "keywords": [],
  "author": "",
  "license": "MIT",
  "scripts": {
    "prepare": "husky",
    "changeset": "changeset",
    "release:version": "changeset version",
    "release:build": "corepack pnpm --filter @senlinz/import-export-wasm build && corepack pnpm --filter @senlinz/import-export build",
    "release:pack": "rm -rf /tmp/import-export-release && mkdir -p /tmp/import-export-release && corepack pnpm --dir packages/wasm pack --pack-destination /tmp/import-export-release && corepack pnpm --dir packages/core pack --pack-destination /tmp/import-export-release",
    "release:check": "corepack pnpm run release:build && corepack pnpm run release:pack"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@nx/js": "^19.8.9",
    "nx": "^19.8.9",
    "@playwright/test": "^1.59.1",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "serve": "^14.2.4"
  },
  "pnpm": {
    "overrides": {
      "axios": "^1.16.0",
      "@babel/helpers": "^7.26.10",
      "@babel/runtime": "^7.26.10",
      "brace-expansion@1": "1.1.14",
      "brace-expansion@2": "2.1.0",
      "cross-spawn@7": "7.0.6",
      "minimatch@3": "3.1.5",
      "minimatch@5": "5.1.9",
      "minimatch@9": "9.0.9",
      "picomatch@2": "2.3.2",
      "picomatch@4": "4.0.4",
      "yaml@1": "1.10.3",
      "js-yaml@3": "3.15.0",
      "js-yaml@4": "4.2.0",
      "ajv": "^8.18.0",
      "tmp@0.2": "0.2.7",
      "diff@4": "4.0.4",
      "on-headers": "1.1.0",
      "fast-uri": "3.1.3",
      "@babel/plugin-transform-modules-systemjs": "7.29.7",
      "form-data": "4.0.6",
      "@babel/core": "7.29.6"
    }
  },
  "lint-staged": {
    "*.{ts,js,mjs}": "prettier --check"
  },
  "engines": {
    "node": ">=16"
  }
}
