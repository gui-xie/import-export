{
  "name": "@senlinz/import-export-wasm",
  "version": "0.1.0",
  "description": "Rust WebAssembly for import/export excel files",
  "type": "module",
  "types": "pkg/imexport_wasm.d.ts",
  "exports": {
    ".": {
      "types": "./pkg/imexport_wasm.d.ts",
      "import": "./pkg/imexport_wasm.js",
      "default": "./pkg/imexport_wasm.js"
    },
    "./pkg/imexport_wasm_bg.wasm": "./pkg/imexport_wasm_bg.wasm"
  },
  "scripts": {
    "build": "wasm-pack build --release --target web && node ./scripts/finalize-pkg.mjs",
    "publish-dry-run": "pnpm publish --dry-run --no-git-checks",
    "cargo-test": "cargo test --lib",
    "e2e-test": "playwright test"
  },
  "files": [
    "pkg/imexport_wasm_bg.wasm",
    "pkg/imexport_wasm.bg.wasm.d.ts",
    "pkg/imexport_wasm.js",
    "pkg/imexport_wasm.d.ts",
    "pkg/snippets/**",
    "README.md",
    "README.zh.md"
  ],
  "author": "senlin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gui-xie/import-export.git"
  },
  "keywords": [
    "rust",
    "wasm",
    "import",
    "export",
    "excel",
    "xlsx",
    "sheet",
    "spreadsheet",
    "OpenXML",
    "browser",
    "client"
  ]
}
