{
  "name": "@senlinz/import-export",
  "version": "1.0.0",
  "description": "import/export excel core",
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.wasm",
    "README.md",
    "README.zh.md"
  ],
  "type": "module",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "scripts": {
    "build": "rollup -c",
    "dev": "rollup -c -w",
    "test:unit": "npm run build && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config jest.config.mjs --runInBand",
    "test": "playwright test -c playwright.config.ts",
    "e2e-serve": "serve -l 8080 ."
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.1",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.1.2",
    "@types/jest": "^29.5.6",
    "@types/node": "^16.18.108",
    "fast-check": "^4.7.0",
    "fflate": "^0.8.2",
    "jest": "^29.7.0",
    "jest-cli": "^29.7.0",
    "rollup": "^4.60.2",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2"
  },
  "author": "senlin",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gui-xie/import-export.git"
  },
  "dependencies": {
    "@senlinz/import-export-wasm": "workspace:*"
  },
  "keywords": [
    "rust",
    "wasm",
    "import",
    "export",
    "excel",
    "xlsx",
    "sheet",
    "spreadsheet",
    "OpenXML",
    "browser",
    "client"
  ]
}
